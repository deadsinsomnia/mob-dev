<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BMI.MainPage"
    BackgroundColor="#F4F6F9">

    <ScrollView>
        <VerticalStackLayout 
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Label 
                Text="BMI Calculator"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#2C3E50"/>

            <Frame 
                BackgroundColor="White"
                CornerRadius="15"
                Padding="20"
                HasShadow="True">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Height (cm)" />
                    <Entry 
                        x:Name="HeightEntry"
                        Placeholder="Enter height in cm"
                        Keyboard="Numeric"
                        TextColor="Black"
                        PlaceholderColor="Gray"/>

                    <Label Text="Weight (kg)" />
                    <Entry 
                        x:Name="WeightEntry"
                        Placeholder="Enter weight in kg"
                        Keyboard="Numeric"
                        TextColor="Black"
                        PlaceholderColor="Gray"/>

                    <Button 
                        Text="Calculate BMI"
                        Clicked="OnCalculateClicked"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        CornerRadius="10"/>

                    <Label 
                        x:Name="ResultLabel"
                        FontSize="18"
                        HorizontalOptions="Center"
                        TextColor="#34495E"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>